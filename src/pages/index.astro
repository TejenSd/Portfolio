---
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tejendra Singh Danu | Full Stack Developer</title>
    <meta name="description" content="Portfolio of Tejendra Singh Danu — Full Stack Developer experienced in .NET, React, and cloud-native systems." />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <!-- Content copied from previous index.html (kept structure and classes) -->
    <header class="site-header">
      <nav class="container nav">
        <a class="brand" href="#home">Tejendra Singh Danu</a>
        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#skills">Skills</a>
          <a href="#projects">Projects</a>
          <a href="#contact">Contact</a>
        </div>
      </nav>
    </header>

    <main id="home">
      <section class="hero container">
        <div class="hero-copy">
          <p class="eyebrow">Full Stack Engineer • .NET & React</p>
          <h1>Building scalable, reliable web applications and APIs.</h1>
          <p class="hero-text">I design and implement production-grade systems using .NET, React, and cloud platforms — focusing on performance, reliability, and maintainability.</p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="#projects">View Projects</a>
            <a class="btn btn-secondary" href="#contact">Let’s Talk</a>
          </div>
        </div>
        <div class="hero-card" aria-label="Design overview">
          <div class="avatar">TD</div>
          <div class="hero-metrics">
            <div>
              <strong>5+</strong>
              <span>Years building production systems</span>
            </div>
            <div>
              <strong>20+</strong>
              <span>Projects delivered end-to-end</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Rest of site content copied from index.html -->

      <section id="about" class="section container">
        <div class="section-heading">
          <p class="eyebrow">About Me</p>
          <h2>I turn complex ideas into intuitive, high-impact experiences.</h2>
        </div>
        <div class="about-grid">
          <div class="about-copy">
            <p>I’m a Full Stack Developer focused on building production-ready services and front-end applications with attention to performance, security, and maintainability.</p>
            <p>From scalable backends to polished front-ends, I deliver end-to-end solutions that solve real problems.</p>
          </div>
          <div class="about-highlights">
            <div class="highlight-card">
              <h3>Architecture</h3>
              <p>Designing reliable service architectures and APIs.</p>
            </div>
            <div class="highlight-card">
              <h3>Performance</h3>
              <p>Optimizing queries, caching, and API responses for low-latency experiences.</p>
            </div>
            <div class="highlight-card">
              <h3>Cloud</h3>
              <p>Deploying and managing systems on AWS with Docker and CI/CD.</p>
            </div>
          </div>
        </div>
      </section>

      <section id="skills" class="section section-alt">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Skills</p>
            <h2>Development skills and tools I bring to projects.</h2>
          </div>
          <div class="skills-grid">
            <article class="card skill-card">
              <span class="card-icon">01</span>
              <h3>Languages</h3>
              <p>C#, JavaScript/TypeScript, SQL, Python</p>
            </article>
            <article class="card skill-card">
              <span class="card-icon">02</span>
              <h3>Frameworks &amp; Libraries</h3>
              <p>.NET Core, ASP.NET, React, Entity Framework</p>
            </article>
            <article class="card skill-card">
              <span class="card-icon">03</span>
              <h3>Cloud &amp; DevOps</h3>
              <p>AWS, Docker, Kubernetes, CI/CD, Git</p>
            </article>
          </div>
        </div>
      </section>

      <section id="projects" class="section container">
        <div class="section-heading">
          <p class="eyebrow">Projects</p>
          <h2>Selected work shaped by clarity, craft, and detail.</h2>
        </div>
        <div class="projects-grid">
          <article class="project-card">
            <div class="project-preview preview-one"></div>
            <h3>Creative Studio Landing Page</h3>
            <p>A premium marketing experience for a creative studio with strong visual hierarchy and storytelling.</p>
            <div class="tags"><span>Web Design</span><span>Brand System</span></div>
          </article>
          <article class="project-card">
            <div class="project-preview preview-two"></div>
            <h3>Product Experience Dashboard</h3>
            <p>A modern analytics interface designed to make complex data feel clear, calm, and actionable.</p>
            <div class="tags"><span>UI</span><span>Product Design</span></div>
          </article>
          <article class="project-card">
            <div class="project-preview preview-three"></div>
            <h3>Personal Brand Experience</h3>
            <p>A refined portfolio experience made to feel polished, personal, and memorable.</p>
            <div class="tags"><span>Portfolio</span><span>Responsive</span></div>
          </article>
        </div>
      </section>

      <section id="contact" class="section section-alt">
        <div class="container contact-card">
          <div>
            <p class="eyebrow">Contact</p>
            <h2>Let’s build something meaningful together.</h2>
          </div>
          <div class="contact-actions">
            <a class="btn btn-primary" href="mailto:tejendra@example.com">Email Me</a>
            <a class="btn btn-secondary" href="https://linkedin.com" target="_blank" rel="noreferrer">LinkedIn</a>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="container footer-content">
        <p>© <span id="year"></span> Tejendra Singh Danu. All rights reserved.</p>
      </div>
    </footer>

    <script src="/script.js"></script>
  </body>
</html>
